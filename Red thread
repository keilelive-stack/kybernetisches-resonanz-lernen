        "\n",
        "    def deploy_protection(self, u, ci, h_u):\n",
        "        \"\"\"Entscheidungslogik basierend auf der Klippen-Gefahr.\"\"\"\n",
        "        if h_u > 4.0 or u >= self.core.u_res:\n",
        "            return \"TRIGGER_DELTA_I_PROTECTION\"\n",
        "        elif h_u > 2.0:\n",
        "            return \"PREPARE_ZETA_SHIELD\"\n",
        "        return \"MONITORING\"\n",
