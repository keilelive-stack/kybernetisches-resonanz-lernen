      "source": [
        "import numpy as np\n",
        "from scipy.integrate import solve_ivp\n",
        "\n",
        "# 1. Instantiate the RedThreadEngine class\n",
        "engine = RedThreadEngine(ciq_nodes, fractal_config)\n",
        "\n",
        "# 2. Define an ODE wrapper function to handle dynamic compactness\n",
        "def ode_wrapper(t, y):\n",
        "    # Extract z from the current state vector\n",
        "    z = y[0]\n",
        "    # Calculate radius r based on structural continuity z\n",
        "    radius_r = engine.r_crit * (1.0 + (1.0 - z))\n",
        "    # Calculate current compactness using the global interpolation function\n",
        "    current_compactness = get_compactness(radius_r)\n",
        "    # Return derivatives from the engine\n",
        "    return engine.ode_system(t, y, current_compactness)\n",
        "\n",
        "# 3. Configure simulation parameters\n",
        "# 100 steps with step size 0.05 -> total time = 5.0\n",
        "dt = 0.05\n",
        "n_steps = 100\n",
        "t_span = (0, n_steps * dt)\n",
        "t_eval = np.linspace(t_span[0], t_span[1], n_steps + 1)\n",
        "\n",
        "# 4. Execute high-precision simulation using solve_ivp with RK45\n",
        "sol = solve_ivp(\n",
        "    ode_wrapper,\n",
        "    t_span,\n",
        "    engine.X0,\n",
        "    t_eval=t_eval,\n",
        "    method='RK45',\n",
        "    rtol=1e-6,\n",
        "    atol=1e-9\n",
        ")\n",
        "\n",
        "# 5. Store and display basic results summary\n",
        "time_points = sol.t\n",
        "state_trajectories = sol.y\n",
        "\n",
        "print(f'Simulation successful: {len(time_points)} time points integrated.')\n",
        "print(f'Final state vector (z, m, q, a, b, c, e):\\n{state_trajectories[:, -1]}')"
