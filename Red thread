        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy.optimize import curve_fit\n",
        "\n",
        "# Daten extrahieren\n",
        "c_data = df_high_fidelity_audit['c'].values\n",
        "e_data = df_high_fidelity_audit['e'].values\n",
        "\n",
        "# 1. Kandidaten-Funktionen definieren\n",
        "def func_linear(x, m, t):\n",
        "    return m * x + t\n",
        "\n",
        "def func_exp(x, a, b, c_offset):\n",
        "    return a * np.exp(-b * x) + c_offset\n",
        "\n",
        "def func_rational(x, a, b, c_offset):\n",
        "    return a / (x + b) + c_offset\n",
        "\n",
        "# 2. Fitting durchführen\n",
        "# Lineares Fitting\n",
        "popt_lin, _ = curve_fit(func_linear, c_data, e_data)\n",
        "e_fit_lin = func_linear(c_data, *popt_lin)\n",
        "\n",
        "# Exponentielles Fitting\n",
        "# Startparameter (p0) schätzen, um Konvergenz zu helfen\n",
        "popt_exp, _ = curve_fit(func_exp, c_data, e_data, p0=[1, 0.5, 0.5], maxfev=10000)\n",
        "e_fit_exp = func_exp(c_data, *popt_exp)\n",
        "\n",
        "# Rationales Fitting (Sättigung)\n",
        "popt_rat, _ = curve_fit(func_rational, c_data, e_data, p0=[1, 1, 0.5], maxfev=10000)\n",
        "e_fit_rat = func_rational(c_data, *popt_rat)\n",
        "\n",
        "# 3. R^2 berechnen (Bestimmtheitsmaß)\n",
        "def calc_r2(y_true, y_pred):\n",
        "    ss_res = np.sum((y_true - y_pred)**2)\n",
        "    ss_tot = np.sum((y_true - np.mean(y_true))**2)\n",
        "    return 1 - (ss_res / ss_tot)\n",
        "\n",
        "r2_lin = calc_r2(e_data, e_fit_lin)\n",
        "r2_exp = calc_r2(e_data, e_fit_exp)\n",
        "r2_rat = calc_r2(e_data, e_fit_rat)\n",
