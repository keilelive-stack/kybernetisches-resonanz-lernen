        "import numpy as np\n",
        "import time\n",
        "from scipy.integrate import solve_ivp\n",
        "\n",
        "# --- MOCK DEFINITIONS TO FIX NameError ---\n",
        "ciq_nodes = {}\n",
        "fractal_config = {'parameters': {'stability_window': 0.7, 'eeg_tau': 0.0083}}\n",
        "\n",
        "class CIQ_CONFIG:\n",
        "    DELTA_THRESHOLD = 0.7\n",
        "\n",
        "class CIQAgentXO:\n",
        "    def run(self, state_desc):\n",
        "        return \"Stable operation. No Iron detected.\"\n",
        "\n",
        "def get_compactness(r):\n",
        "    return 1.2 # Mock value for demonstration\n",
        "\n",
        "# --- ENGINE DEFINITION ---\n",
        "class RedThreadEngine:\n",
        "    def __init__(self, nodes_dict, fractal_cfg):\n",
        "        self.G = 6.67430e-11\n",
        "        self.c_light = 299792458.0\n",
        "        self.hbar = 1.054571817e-34\n",
        "        self.k_B = 1.380649e-23\n",
        "        self.ln2 = np.log(2)\n",
        "        self.sigma_base = 0.05\n",
        "        self.H_0 = 70e3 / 3.086e19\n",
        "        self.r_planck = np.sqrt(self.hbar * self.G / self.c_light**3)\n",
        "        self.r_crit = np.sqrt(2) * self.r_planck\n",
        "        self.E_planck = np.sqrt(self.hbar * self.c_light**5 / self.G)\n",
        "        self.E_crit = self.E_planck / np.sqrt(2)\n",
        "        self.Delta = fractal_cfg['parameters'].get('stability_window', 0.7)\n",
        "        self.k, self.mu, self.gamma = 0.15, 0.10, 0.25\n",
        "        self.lambda_param, self.beta = 0.5, 0.12\n",
        "        self.ciq_nodes = nodes_dict\n",
        "        self.X0 = [1.0, 0.01, 0.05, 0.0, 0.0, 0.5, 1.0, 0.0]\n",
        "        self.boundary_violated = False\n",
        "\n",
        "    def calculate_entropy_metrics(self, delta_val, compactness):\n",
        "        sigma_dyn = self.sigma_base * max(compactness, 1e-3)\n",
        "        i_order = np.exp(-((delta_val - 0.7)**2) / (2 * sigma_dyn**2))\n",
        "        s_entropy = 1 - i_order\n",
        "        hubble_tension = ((delta_val - 0.7) / (sigma_dyn**2)) * i_order\n",
        "        return i_order, s_entropy, hubble_tension\n",
        "\n",
        "    def ode_system(self, t, X, compactness_val):\n",
        "        z, m, q, a, b, c, e, debt = X\n",
        "        _, _, hubble_tension = self.calculate_entropy_metrics(c, compactness_val)\n",
        "        r = self.r_crit * (1.0 + (1.0 - z)) / max(compactness_val, 1.0)\n",
        "        quad_coeff = self.G / (r * self.c_light**4)\n",
        "        dzdt = -0.05 * m * (1 - z) - 0.01 * q\n",
        "        dmdt = 0.2 * (1 - z) * (self.Delta - abs(self.Delta - c))\n",
        "        dqdt = self.mu * m * (1 - c) + 0.05 * q * (1 - q)\n",
        "        dadt = self.k * m * q * c - 0.03 * a\n",
        "        dbdt = self.gamma * (a**2) * (1 - c) - 0.1 * b\n",
        "        dcdt = self.lambda_param * (self.Delta - abs(q - a)) - 0.2 * b - 0.01 * hubble_tension\n",
        "        dedt = self.beta * (q + a) - 0.05 * e + 0.3 * b + (quad_coeff * e**2)\n",
        "        ddebt_dt = abs(hubble_tension) * e\n",
        "        if (4 * quad_coeff * e) > 1.0:\n",
        "            self.boundary_violated = True\n",
        "        return [dzdt, dmdt, dqdt, dadt, dbdt, dcdt, dedt, ddebt_dt]\n",
        "\n",
        "# --- AGENT WRAPPER DEFINITION ---\n",
        "class CIQ_Agent_Wrapper:\n",
        "    def __init__(self):\n",
        "        self.agent_xo = CIQAgentXO()\n",
        "        self.config = CIQ_CONFIG\n",
        "        self.history = []\n",
        "        self.MAX_ENTROPY_DEBT = 50.0\n",
        "        self.MAX_HUBBLE_TENSION = 1.0\n",
        "\n",
        "    def monitor_state(self, state_vector, hubble_tension):\n",
        "        z, m, q, a, b, c, e, entropy_debt = state_vector\n",
        "        state_desc = f\"ZIS:{z:.3f}, Moebius:{m:.3f}, DM:{q:.3f}, Matter:{a:.3f}, BH:{b:.3f}, CIQ:{c:.3f}, Energy:{e:.3f}, Debt:{entropy_debt:.3f}\"\n",
        "        report = self.agent_xo.run(state_desc)\n",
        "        report_str = str(report)\n",
        "        actions = []\n",
        "        is_iron_tipping_point = \"Iron\" in report_str or \"Stabilit&#224;t\" in report_str\n",
        "\n",
        "        if c < self.config.DELTA_THRESHOLD:\n",
        "            actions.append(\"TRIGGER_SINGULARITY_PATCH\")\n",
        "        if is_iron_tipping_point:\n",
        "            actions.append(\"LOCK_STABILITY_CORE\")\n",
        "            actions.append(\"TRIGGER_SYSTEM_RECALIBRATION\")\n",
        "        if \"W\" in report_str:\n",
        "            actions.append(\"INJECT_EVENT_HORIZON\")\n",
        "        if entropy_debt > self.MAX_ENTROPY_DEBT:\n",
        "            if \"TRIGGER_SINGULARITY_PATCH\" not in actions:\n",
        "                actions.append(\"TRIGGER_SINGULARITY_PATCH\")\n",
        "            actions.append(\"DEBT_RESTRUCTURE\")\n",
        "        if abs(hubble_tension) > self.MAX_HUBBLE_TENSION:\n",
        "            actions.append(\"HUBBLE_DAMPING_PROTOCOL\")\n",
        "\n",
        "        log_entry = {\n",
        "            \"timestamp\": time.time(),\n",
        "            \"state\": state_vector.tolist(),\n",
        "            \"hubble_tension\": hubble_tension,\n",
        "            \"report\": report,\n",
        "            \"actions\": actions,\n",
        "            \"iron_tipping_point_reached\": is_iron_tipping_point\n",
        "        }\n",
        "        self.history.append(log_entry)\n",
        "        return log_entry\n",
        "\n",
        "# --- INTEGRATED SIMULATION ---\n",
        "print(\"--- Starting Simulation with Entropy Debt & Hubble Tension Monitoring ---\")\n",
        "\n",
        "engine = RedThreadEngine(ciq_nodes, fractal_config)\n",
        "agent = CIQ_Agent_Wrapper()\n",
        "\n",
        "def simulation_wrapper(t, y):\n",
        "    z = y[0]\n",
        "    radius_r = engine.r_crit * (1.0 + (1.0 - z))\n",
        "    current_compactness = float(get_compactness(radius_r))\n",
        "    return engine.ode_system(t, y, current_compactness)\n",
        "\n",
        "t_span = (0, 5.0)\n",
        "t_eval = np.arange(0, 5.05, 0.05)\n",
        "\n",
        "sol = solve_ivp(\n",
        "    simulation_wrapper,\n",
        "    t_span,\n",
        "    engine.X0,\n",
        "    t_eval=t_eval,\n",
        "    method='RK45',\n",
        "    rtol=1e-7,\n",
        "    atol=1e-10\n",
        ")\n",
        "\n",
        "audit_results = []\n",
        "for i in range(len(sol.t)):\n",
        "    current_state = sol.y[:, i]\n",
        "    c_val = current_state[5]\n",
        "    z_val = current_state[0]\n",
        "\n",
        "    radius_r = engine.r_crit * (1.0 + (1.0 - z_val))\n",
        "    current_compactness = float(get_compactness(radius_r))\n",
        "    _, _, h_tension = engine.calculate_entropy_metrics(c_val, current_compactness)\n",
        "\n",
        "    log = agent.monitor_state(current_state, h_tension)\n",
        "    audit_results.append(log)\n",
        "\n",
        "print(f\"Simulation Completed: {len(sol.t)} steps.\")\n",
        "\n",
        "debt_interventions = [log for log in audit_results if \"DEBT_RESTRUCTURE\" in log['actions']]\n",
        "hubble_interventions = [log for log in audit_results if \"HUBBLE_DAMPING_PROTOCOL\" in log['actions']]\n",
        "\n",
