        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import json\n",
        "\n",
        "# ==============================================================================\n",
        "# 1. CIQ MASTER REGISTRY (Basierend auf Sept 2025 Dokumenten)\n",
        "# ==============================================================================\n",
        "class CIQ_Master_Registry:\n",
        "    def __init__(self):\n",
        "        # Parameter extrahiert aus: Eisen_Resonanz_Erweiterung_v1.docx\n",
        "        # und Eisen_Resonanz_Fits_realdata.docx\n",
        "        self.zeta = 3840.0  # Der universelle Zeta-Knoten\n",
        "        self.regimes = {\n",
        "            \"Zellteilung\": {\n",
        "                \"A\": 0.5, \"B\": 0.02, \"n\": 2.0, \"u_range\": (0.0, 0.1),\n",
        "                \"unit\": \"s\", \"desc\": \"Ordnungsschub / DNA-Replikation\"\n",
        "            },\n",
        "            \"Stabilitaet\": {\n",
        "                \"A\": 0.05, \"B\": 0.003, \"n\": 2.0, \"u_range\": (0.1, 1.0),\n",
        "                \"unit\": \"Life\", \"desc\": \"Nachhaltiges Gleichgewicht\"\n",
        "            },\n",
        "            \"Gehirntod\": {\n",
        "                \"A\": 0.6, \"B\": 0.03, \"n\": 4.0, \"u_range\": (0.0, 2.0),\n",
        "                \"unit\": \"min\", \"desc\": \"Finaler Reset / Informations-Transfer\"\n",
        "            },\n",
        "            \"Kosmos\": {\n",
        "                \"A\": 0.584, \"B\": 1.034, \"n\": 4.0, \"u_range\": (0.0, 50.0),\n",
        "                \"unit\": \"Gyr\", \"desc\": \"Hubble-Spannung / Kollaps-Modell\"\n",
        "            }\n",
        "        }\n",
        "\n",
        "# ==============================================================================\n",
        "# 2. EISEN-RESONANZ ENGINE (Mathematischer Kern)\n",
        "# ==============================================================================\n",
        "class EisenResonanzEngine:\n",
        "    @staticmethod\n",
        "    def calculate_ci(u, A, B, n):\n",
        "        \"\"\"Das universelle Formgesetz: CI(u) = exp(-A*u - B*u^n)\"\"\"\n",
        "        return np.exp(-A * u - B * (u**n))\n",
        "\n",
        "    @staticmethod\n",
        "    def calculate_hazard(u, A, B, n):\n",
        "        \"\"\"Die Hazard-Rate h(u): Risiko des Resets\"\"\"\n",
        "        return A + n * B * (u**(n-1))\n",
        "\n",
        "    @staticmethod\n",
        "    def calculate_pi_switch(ci_val, zeta):\n",
        "        \"\"\"Der Schutzschalter S_Pi: Skalierung der mikroskopischen Stabilitaet\"\"\"\n",
        "        # Annahme: I(u)/I0 = 1 (maximale Informationserhaltung fuer den Audit)\n",
        "        # Vermeidung von Overflow-Warnungen bei extrem hohen Potenzen\n",
        "        with np.errstate(over='ignore'):\n",
        "            return np.float64(1.0 / ci_val)**zeta\n",
        "\n",
        "# ==============================================================================\n",
        "# 3. AGENT XΩ MASTER-INTELLIGENZ\n",
        "# ==============================================================================\n",
        "class Agent_XO_Master:\n",
        "    def __init__(self, registry):\n",
        "        self.registry = registry\n",
        "        self.engine = EisenResonanzEngine()\n",
        "\n",
        "    def perform_deep_audit(self, regime_name, current_u):\n",
        "        cfg = self.registry.regimes[regime_name]\n",
        "        A, B, n = cfg['A'], cfg['B'], cfg['n']\n",
        "\n",
        "        ci = self.engine.calculate_ci(current_u, A, B, n)\n",
        "        h_u = self.engine.calculate_hazard(current_u, A, B, n)\n",
        "        s_pi = self.engine.calculate_pi_switch(ci, self.registry.zeta)\n",
        "\n",
        "        # Entscheidungs-Logik basierend auf dem 'Reset-Modell'\n",
        "        status = \"STABIL\"\n",
        "        action = \"MONITORING\"\n",
        "\n",
        "        if n >= 4 and h_u > 1.0:\n",
        "            status = \"RESET_GEFAHR\"\n",
        "            action = \"ACTIVATE_ZETA_SYNCHRONIZATION\"\n",
        "\n",
        "        if ci < 0.5:\n",
        "            status = \"INFO_TRANSFER_REQUIRED\"\n",
        "            action = \"TRIGGER_DELTA_I_PROTECTION\"\n",
        "\n",
        "        return {\n",
        "            \"Regime\": regime_name,\n",
        "            \"u\": current_u,\n",
        "            \"Continuity_Index\": round(ci, 6),\n",
        "            \"Hazard_Rate\": round(h_u, 6),\n",
        "            \"S_Pi_Switch\": f\"{s_pi:.2e}\",\n",
        "            \"System_Status\": status,\n",
        "            \"Agent_Action\": action\n",
        "        }\n",
        "\n",
        "# ==============================================================================\n",
        "# 4. WISSENSCHAFTLICHE VISUALISIERUNG & EXECUTION\n",
        "# ==============================================================================\n",
        "reg = CIQ_Master_Registry()\n",
        "agent = Agent_XO_Master(reg)\n",
        "engine = EisenResonanzEngine()\n",
        "\n",
        "# Plot-Setup\n",
        "u_vals = np.linspace(0.001, 1.2, 500)\n",
        "plt.figure(figsize=(14, 7))\n",
        "\n",
        "print(\"--- AGENT XΩ MASTER AUDIT START ---\")\n",
        "audit_results = []\n",
        "\n",
        "for name, cfg in reg.regimes.items():\n",
        "    # 1. Audit fuer einen kritischen Punkt durchfuehren\n",
        "    res = agent.perform_deep_audit(name, current_u=0.95)\n",
        "    audit_results.append(res)\n",
        "\n",
        "    # 2. Kurve zeichnen\n",
        "    y_vals = engine.calculate_ci(u_vals, cfg['A'], cfg['B'], cfg['n'])\n",
        "    plt.plot(u_vals, y_vals, label=f\"{name} (n={cfg['n']})\", linewidth=2)\n",
        "\n",
        "# Graphische Veredelung\n",
        "plt.axvline(0.7, color='red', linestyle='--', label='Eisen-Resonanz (Node 77)')\n",
        "plt.title(\"CIQ Master-Audit: Fraktale Eisen-Resonanz (Bio vs. Kosmos)\")\n",
        "plt.xlabel(\"Normierte Zeit / Kontinuum (u)\")\n",
        "plt.ylabel(\"Continuity Index CI(u)\")\n",
        "plt.legend()\n",
        "plt.grid(True, alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Audit-Bericht ausgeben\n",
        "df_report = pd.DataFrame(audit_results)\n",
        "display(df_report)\n"
      ]
    },
