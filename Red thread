        "    for name, p in core.regimes.items():\n",
        "        ci_vals = [core.ci_law(u, p) for u in u_vals]\n",
        "        plt.plot(u_vals, ci_vals, label=f\"{name} (n={p['n']})\", color=p['color'], lw=2)\n",
