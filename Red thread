        "import re\n",
        "\n",
        "# Suche nach 'Step'-Einträgen und den darauffolgenden 'Actions'\n",
        "step_blocks = []\n",
        "\n",
        "# Nutze finditer, um die Startpositionen der Step-Logs zu bekommen\n",
        "step_matches = list(re.finditer(r'(Step \\d+: c=[\\d\\.]+ \\| \\[.*?\\] [A-Z]+)', extracted_text_pro))\n",
        "\n",
        "for i, match in enumerate(step_matches):\n",
        "    step_line = match.group(1)\n",
        "    start_idx = match.end()\n",
        "\n",
        "    # Das Suchfenster für die Actions geht bis zum nächsten Step oder max 300 Zeichen\n",
        "    end_idx = step_matches[i+1].start() if i + 1 < len(step_matches) else start_idx + 300\n",
        "    window = extracted_text_pro[start_idx:end_idx]\n",
        "\n",
